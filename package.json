{
  "name": "nextjs-reusable-table",
  "version": "3.5.2",
  "description": "A highly customizable and reusable table component for Next.js applications, built with TypeScript and the latest technologies.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninsau/nextjs-reusable-table.git"
  },
  "bugs": {
    "url": "https://github.com/ninsau/nextjs-reusable-table/issues"
  },
  "homepage": "https://github.com/ninsau/nextjs-reusable-table#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup src/index.ts --format esm,cjs --dts --out-dir dist && npm run build:css",
    "build:css": "tailwindcss -i src/styles/tableStyles.css -o dist/index.css --minify",
    "build:css-compat": "tailwindcss -i src/styles/tableStyles.css -o dist/compat.css --minify",
    "prepublishOnly": "npm run build",
    "size": "bundlesize",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "ninsau",
  "license": "ISC",
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "bundlesize": "^0.18.1",
    "postcss": "^8.4.47",
    "react-loading-skeleton": "^3.5.0",
    "tailwindcss": "^3.4.13",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "next": ">=12",
    "react": ">=16",
    "react-dom": ">=16",
    "tailwindcss": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "bundlesize": [
    {
      "path": "dist/index.js",
      "maxSize": "50 kB"
    },
    {
      "path": "dist/index.mjs",
      "maxSize": "50 kB"
    },
    {
      "path": "dist/index.css",
      "maxSize": "10 kB"
    }
  ],
  "keywords": [
    "nextjs",
    "next.js",
    "react",
    "typescript",
    "table",
    "data table",
    "reusable component",
    "component",
    "ui component",
    "data grid",
    "data display",
    "data visualization",
    "frontend",
    "frontend component",
    "react component",
    "nextjs component",
    "typescript component",
    "npm package",
    "reusable",
    "customizable",
    "responsive",
    "ui library",
    "data",
    "table component",
    "action dropdown",
    "skeleton loader",
    "no content component",
    "modern",
    "tailwindcss",
    "open source"
  ]
}